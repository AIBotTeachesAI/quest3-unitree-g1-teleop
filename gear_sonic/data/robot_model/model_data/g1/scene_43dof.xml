<mujoco model="g1_43dof scene">
  <include file="g1_29dof_with_hand.xml"/>
  <!-- Note that the hand model in g1_29dof_with_hand.xml is not stable for simulation. -->

  <statistic center="0 0 0.5" extent="2.0"/>

  <visual>
    <headlight diffuse="0.5 0.5 0.5" ambient="0.4 0.38 0.35" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <!-- Sky (warm indoor tone) -->
    <texture type="skybox" builtin="gradient" rgb1="0.55 0.55 0.58" rgb2="0.35 0.35 0.38" width="512" height="3072"/>

    <!-- Wood floor -->
    <texture type="2d" name="woodfloor" builtin="flat" rgb1="0.65 0.45 0.28" rgb2="0.55 0.38 0.22"
      width="512" height="512" mark="random" markrgb="0.60 0.42 0.25" random="0.02"/>
    <material name="woodfloor" texture="woodfloor" texuniform="true" texrepeat="8 8" reflectance="0.15"
      specular="0.3" shininess="0.5"/>

    <!-- Wall material -->
    <texture type="2d" name="walltex" builtin="flat" rgb1="0.88 0.85 0.80" rgb2="0.85 0.82 0.77"
      width="256" height="256"/>
    <material name="wall_mat" texture="walltex" texuniform="true" texrepeat="2 2" reflectance="0.05"
      rgba="0.88 0.85 0.80 1"/>

  </asset>

  <worldbody>
    <!-- Lighting: warm ceiling lights -->
    <light pos="0 0 2.8" dir="0 0 -1" directional="false" diffuse="0.8 0.75 0.65" castshadow="true"/>
    <light pos="-2 2 2.5" dir="0.3 -0.3 -1" directional="false" diffuse="0.4 0.38 0.35" castshadow="false"/>
    <light pos="2 -2 2.5" dir="-0.3 0.3 -1" directional="false" diffuse="0.4 0.38 0.35" castshadow="false"/>

    <!-- Floor -->
    <geom name="floor" size="4 4 0.05" type="plane" material="woodfloor"/>

    <!-- Walls (room 8m x 8m, 3m tall, centered on origin) -->
    <geom name="wall_back"  type="box" size="4 0.05 1.5" pos="0  4 1.5" material="wall_mat" contype="1" conaffinity="1"/>
    <geom name="wall_front" type="box" size="4 0.05 1.5" pos="0 -4 1.5" material="wall_mat" contype="1" conaffinity="1"/>
    <geom name="wall_left"  type="box" size="0.05 4 1.5" pos="-4 0 1.5" material="wall_mat" contype="1" conaffinity="1"/>
    <geom name="wall_right" type="box" size="0.05 4 1.5" pos="4  0 1.5" material="wall_mat" contype="1" conaffinity="1"/>

    <!-- Site -->
    <site name="com_marker" pos="0.1 0 0" size="0.05" rgba="1 0 0 1" type="sphere"/>
  </worldbody>

  <default>
    <geom friction="1.0"/>
  </default>
</mujoco>
